<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SITA.Maui.SignInPage"
             Title="Sign In">

    <VerticalStackLayout Padding="32" Spacing="16" VerticalOptions="Center">

        <Label Text="Entrar" FontSize="28" FontAttributes="Bold" HorizontalOptions="Center"/>

        <Entry x:Name="NameEntry" Placeholder="Nome de usuário"/>
        <Entry x:Name="PasswordEntry" Placeholder="Senha" IsPassword="True"/>

        <Label x:Name="ErrorLabel" TextColor="Red" IsVisible="False"/>

        <Button Text="Entrar" Clicked="OnSignInClicked"/>
        <Button Text="Criar conta" Clicked="OnGoToSignUpClicked" BackgroundColor="Transparent" TextColor="Blue"/>

    </VerticalStackLayout>
</ContentPage>