<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SITA.Maui.SignUpPage"
             Title="Criar Conta">

    <VerticalStackLayout Padding="32" Spacing="16" VerticalOptions="Center">

        <Label Text="Criar Conta" FontSize="28" FontAttributes="Bold" HorizontalOptions="Center"/>

        <Entry x:Name="NameEntry"          Placeholder="Nome"/>
        <Entry x:Name="CpfEntry"           Placeholder="CPF"/>
        <Entry x:Name="IdadeEntry"         Placeholder="Idade" Keyboard="Numeric"/>
        <Entry x:Name="NascimentoEntry"    Placeholder="Data de nascimento (dd/mm/aaaa)"/>
        <Entry x:Name="PasswordEntry"      Placeholder="Senha" IsPassword="True"/>
        <Entry x:Name="ConfirmPassEntry"   Placeholder="Confirmar senha" IsPassword="True"/>

        <Label x:Name="ErrorLabel" TextColor="Red"   IsVisible="False"/>
        <Label x:Name="SuccessLabel" TextColor="Green" IsVisible="False"/>

        <Button Text="Cadastrar" Clicked="OnSignUpClicked"/>
        <Button Text="Voltar" Clicked="OnBackClicked" BackgroundColor="Transparent" TextColor="Blue"/>

    </VerticalStackLayout>
</ContentPage>